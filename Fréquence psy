/* CORE */
function checkAccess(id){if(!["b1","b2","b3"].includes(id))return true;if(unlocked[id])return true;const code=prompt("Code d'accès :");if(code===ACCESS_CODE){unlocked[id]=true;return true}alert("Code incorrect.");return false}

function createBubble(b){
  const el=document.createElement("div");el.className="bubble "+b.type;el.id=b.id;el.textContent=b.text;
  el.style.left=b.x+"px";el.style.top=b.y+"px";el.style.animationDelay=(Math.random()*5)+"s";
  if(!["b1","b2","b3"].includes(b.id))el.classList.add("hidden");
  el.onclick=e=>{
    e.stopPropagation();if(moved)return;if(!checkAccess(b.id))return;
    playBubbleSound();
    if(b.article){openCard(articles[b.article]);return}
    if(b.resource){openCard(resources[b.resource]);return}
    if(b.group==="subject"){openOnlyGroup("subject",b.id);return}
    if(b.group==="dateSubject"){openOnlyGroup("dateSubject",b.id,true);return}
    if(b.group==="resourceSubject"){openOnlyGroup("resourceSubject",b.id);return}
    toggleBranch(b.id)
  };
  canvas.appendChild(el)
}

function show(id){const el=document.getElementById(id);if(el){el.classList.remove("hidden");el.classList.add("visible")}}
function hide(id){const el=document.getElementById(id);if(el){el.classList.add("hidden");el.classList.remove("visible")}}
function toggleBranch(id){const b=bubbles.find(x=>x.id===id);if(!b)return;const open=b.children.some(c=>{const el=document.getElementById(c);return el&&!el.classList.contains("hidden")});if(open)collapseChildren(id);else b.children.forEach(show);drawLines()}
function collapseChildren(id){const b=bubbles.find(x=>x.id===id);if(!b)return;b.children.forEach(c=>{collapseChildren(c);hide(c)})}
function openOnlyGroup(group,id,hideOthers=false){bubbles.filter(b=>b.group===group&&b.id!==id).forEach(b=>{collapseChildren(b.id);if(hideOthers)hide(b.id)});const sel=bubbles.find(b=>b.id===id);sel.children.forEach(show);drawLines()}

function drawLines(){
  lines.innerHTML="";
  bubbles.forEach(p=>{
    const pe=document.getElementById(p.id);if(!pe||pe.classList.contains("hidden"))return;
    const pw=p.type&&p.type.includes("small")?134:148;
    p.children.forEach(c=>{
      const ce=document.getElementById(c);if(!ce||ce.classList.contains("hidden"))return;
      const child=bubbles.find(b=>b.id===c);if(!child)return;
      const cw=child.type&&child.type.includes("small")?134:148;
      const l=document.createElementNS("http://www.w3.org/2000/svg","line");
      l.setAttribute("x1",p.x+pw/2);l.setAttribute("y1",p.y+pw/2);
      l.setAttribute("x2",child.x+cw/2);l.setAttribute("y2",child.y+cw/2);
      lines.appendChild(l)
    })
  })
}

function openCard(card){
  modal.classList.remove("hidden");
  modalTitle.textContent=card.title;
  modalTags.innerHTML=(card.tags||[]).map(t=>`<span class="modal-tag">${t}</span>`).join("");
  modalContent.innerHTML=card.content;
  modal.querySelector(".modal-box").scrollTop=0
}

document.getElementById("closeModal").onclick=()=>modal.classList.add("hidden");
modal.onclick=e=>{if(e.target===modal)modal.classList.add("hidden")};
document.addEventListener("keydown",e=>{if(e.key==="Escape")modal.classList.add("hidden")});

/* ── Adaptive initial view ── */
const isMobile=window.innerWidth<768;
scale=isMobile?0.45:1;
posX=isMobile?-260:-1200;
posY=isMobile?-180:-500;

function update(){canvas.style.transform=`translate(${posX}px,${posY}px) scale(${scale})`}

/* ── Mouse ── */
viewport.onmousedown=e=>{dragging=true;moved=false;startX=e.clientX-posX;startY=e.clientY-posY};
window.onmouseup=()=>{dragging=false;setTimeout(()=>moved=false,30)};
window.onmousemove=e=>{if(!dragging)return;if(Math.abs(e.clientX-startX-posX)>3||Math.abs(e.clientY-startY-posY)>3)moved=true;posX=e.clientX-startX;posY=e.clientY-startY;update()};
viewport.addEventListener("wheel",e=>{e.preventDefault();const old=scale;scale+=e.deltaY*-.001;scale=Math.min(Math.max(.28,scale),2.6);const r=viewport.getBoundingClientRect(),mx=e.clientX-r.left,my=e.clientY-r.top;posX=mx-((mx-posX)/old)*scale;posY=my-((my-posY)/old)*scale;update()},{passive:false});

/* ── Touch ── */
let lastTouchDist=null,lastTouchMid=null;
function touchDist(e){const dx=e.touches[0].clientX-e.touches[1].clientX,dy=e.touches[0].clientY-e.touches[1].clientY;return Math.sqrt(dx*dx+dy*dy)}
function touchMid(e){return{x:(e.touches[0].clientX+e.touches[1].clientX)/2,y:(e.touches[0].clientY+e.touches[1].clientY)/2}}

viewport.addEventListener("touchstart",e=>{
  e.preventDefault();
  if(e.touches.length===1){
    dragging=true;moved=false;
    startX=e.touches[0].clientX-posX;
    startY=e.touches[0].clientY-posY;
    lastTouchDist=null;
  } else if(e.touches.length===2){
    dragging=false;
    lastTouchDist=touchDist(e);
    lastTouchMid=touchMid(e);
  }
},{passive:false});

viewport.addEventListener("touchmove",e=>{
  e.preventDefault();
  if(e.touches.length===1&&dragging){
    const nx=e.touches[0].clientX-startX,ny=e.touches[0].clientY-startY;
    if(Math.abs(nx-posX)>4||Math.abs(ny-posY)>4)moved=true;
    posX=nx;posY=ny;update();
  } else if(e.touches.length===2&&lastTouchDist){
    const newDist=touchDist(e);
    const mid=touchMid(e);
    const ratio=newDist/lastTouchDist;
    const old=scale;
    scale=Math.min(Math.max(.28,scale*ratio),2.6);
    const r=viewport.getBoundingClientRect();
    const mx=mid.x-r.left,my=mid.y-r.top;
    posX=mx-((mx-posX)/old)*scale;
    posY=my-((my-posY)/old)*scale;
    lastTouchDist=newDist;
    lastTouchMid=mid;
    update();
  }
},{passive:false});

viewport.addEventListener("touchend",e=>{
  if(e.touches.length<2)lastTouchDist=null;
  if(e.touches.length===0){dragging=false;setTimeout(()=>moved=false,50);}
},{passive:false});

const searchable=[
  ...Object.entries(articles).map(([id,a])=>({title:a.title,subtitle:a.tags.join(" · "),keywords:(a.title+" "+a.tags.join(" ")).toLowerCase(),article:id})),
  ...Object.entries(resources).map(([id,r])=>({title:r.title,subtitle:r.tags.join(" · "),keywords:(r.title+" "+r.tags.join(" ")).toLowerCase(),resource:id})),
  ...topics.map(t=>({title:t,subtitle:"Sujet",keywords:t.toLowerCase(),topic:t}))
];
searchInput.oninput=()=>{
  const q=searchInput.value.trim().toLowerCase();searchResults.innerHTML="";
  if(!q){searchResults.classList.add("hidden");return}
  const results=searchable.filter(i=>i.keywords.includes(q)||i.title.toLowerCase().includes(q));
  if(!results.length){searchResults.innerHTML='<div class="result">Aucun résultat</div>';searchResults.classList.remove("hidden");return}
  results.slice(0,8).forEach(item=>{
    const div=document.createElement("div");div.className="result";
    div.innerHTML=`<strong>${item.title}</strong><small>${item.subtitle}</small>`;
    div.onclick=()=>{
      searchResults.classList.add("hidden");searchInput.value="";
      if(item.article)openCard(articles[item.article]);
      if(item.resource)openCard(resources[item.resource]);
      if(item.topic){const b=bubbles.find(x=>x.group==="subject"&&x.topic===item.topic);if(b){show("b2");show(b.id);openOnlyGroup("subject",b.id)}}
    };
    searchResults.appendChild(div)
  });
  searchResults.classList.remove("hidden")
};

bubbles.forEach(createBubble);drawLines();update();
</script>
